---
import '../styles/docs.css';
import Navbar from '../components/Navbar.astro';

interface Heading { id:string; label:string; }
interface NoteLink { title:string; href:string; }
interface Props {
  title:string;
  description:string;
  headings:Heading[];
  current:string;
  previous?:NoteLink;
  next?:NoteLink;
}
const { title, description, headings, current, previous, next } = Astro.props;
const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, '')}`;
const notes = [
  { id:'installation', title:'Installation', href:'/programming-languages/cpp/installation/' },
  { id:'input-output', title:'Input and Output', href:'/programming-languages/cpp/input-output/' },
];
---
<!doctype html>
<html lang="en" style="--collection-accent:#659ad2">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg?v=2')} />
    <title>{title} · C++ Notes · Braindump</title>
  </head>
  <body>
    <Navbar />
    <div class="docs-shell">
      <aside class="docs-sidebar" aria-label="C++ notes">
        <a class:list={['sidebar-overview', { active:current === 'overview' }]} href={withBase('/programming-languages/cpp/')} aria-current={current === 'overview' ? 'page' : undefined}>Overview</a>
        <div class="sidebar-divider" aria-hidden="true"></div>
        <details class="sidebar-group" open>
          <summary>Getting started <span aria-hidden="true">⌄</span></summary>
          <nav>{notes.map((note) => <a class:list={{ active:current === note.id }} href={withBase(note.href)} aria-current={current === note.id ? 'page' : undefined}>{note.title}</a>)}</nav>
        </details>
      </aside>
      <main class="docs-content">
        <nav class="docs-breadcrumb" aria-label="Breadcrumb"><a href={base}>Home</a><span>/</span><a href={withBase('/programming-languages/')}>Programming Languages</a><span>/</span><span>C++</span></nav>
        <header class="article-header"><p>C++ Documentation</p><h1>{title}</h1><span>{description}</span></header>
        <article class="docs-article"><slot /></article>
        <nav class="page-navigation" aria-label="Documentation pages">
          {previous ? <a class="page-link previous" href={withBase(previous.href)}><small>← Previous</small><strong>{previous.title}</strong></a> : <span class="page-link disabled"><small>← Previous</small><strong>Start of notes</strong></span>}
          {next ? <a class="page-link next" href={withBase(next.href)}><small>Next →</small><strong>{next.title}</strong></a> : <span class="page-link next disabled"><small>Next →</small><strong>More notes soon</strong></span>}
        </nav>
      </main>
      <aside class="contents-sidebar" aria-label="On this page"><p>On this page</p><nav>{headings.map((heading) => <a href={`#${heading.id}`}>{heading.label}</a>)}</nav></aside>
    </div>
    <script>
      const sections = [...document.querySelectorAll<HTMLElement>('.docs-article section[id]')];
      const links = [...document.querySelectorAll<HTMLAnchorElement>('.contents-sidebar a')];
      let ticking = false;

      function updateActiveSection() {
        let active = sections[0]?.id;
        for (const section of sections) {
          if (section.getBoundingClientRect().top <= 150) active = section.id;
          else break;
        }
        links.forEach((link) => {
          const isActive = link.hash === `#${active}`;
          link.classList.toggle('active', isActive);
          if (isActive) link.setAttribute('aria-current', 'location');
          else link.removeAttribute('aria-current');
        });
        ticking = false;
      }

      document.addEventListener('scroll', () => {
        if (!ticking) { requestAnimationFrame(updateActiveSection); ticking = true; }
      }, { passive:true });
      updateActiveSection();
    </script>
  </body>
</html>
