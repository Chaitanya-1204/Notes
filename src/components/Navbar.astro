---
import '../styles/navbar.css';
const pages = [
  { title: 'Programming Languages', description: 'Language collection', href: '/programming-languages/' },
  { title: 'C++ Installation', description: 'C++ documentation', href: '/programming-languages/cpp/installation/' },
  { title: 'C++ Input and Output', description: 'C++ documentation', href: '/programming-languages/cpp/input-output/' },
  { title: 'Generative AI', description: 'AI collection', href: '/generative-ai/' },
  { title: 'DSA', description: 'Data structures and algorithms', href: '/dsa/' },
  { title: 'Sorting', description: 'DSA sorting notes', href: '/dsa/sorting/' },
  { title: 'System Design', description: 'System design collection', href: '/system-design/' },
  { title: 'Developer Tools', description: 'Development tools collection', href: '/developer-tools/' },
  { title: 'Git', description: 'Version control notes', href: '/developer-tools/' },
];
---
<header class="header">
  <a class="logo" href="/" aria-label="Braindump home"><span class="logo-mark"><img src="/favicon.svg" alt="" /></span><span>Braindump</span></a>
  <div class="search-shell" data-pages={JSON.stringify(pages)}>
    <label class="search">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="m16.5 16.5 4 4" stroke="currentColor" stroke-width="2"/></svg>
      <input type="search" placeholder="Search notes…" autocomplete="off" aria-label="Search notes" aria-controls="navbar-search-results" aria-expanded="false" role="combobox" />
      <kbd>⌘ K</kbd>
    </label>
    <div class="search-results" id="navbar-search-results" role="listbox" aria-label="Search results" hidden></div>
  </div>
</header>
<script>
  const shell = document.querySelector<HTMLElement>('.search-shell');
  const input = shell?.querySelector<HTMLInputElement>('input');
  const results = shell?.querySelector<HTMLElement>('.search-results');
  const shortcut = shell?.querySelector<HTMLElement>('kbd');
  const pages = JSON.parse(shell?.dataset.pages ?? '[]') as Array<{ title:string; description:string; href:string }>;
  if (shortcut && !/Mac|iPhone|iPad|iPod/.test(navigator.platform)) shortcut.textContent = 'Ctrl K';
  function closeSearch() { if (results) results.hidden = true; input?.setAttribute('aria-expanded','false'); }
  function runSearch() {
    if (!input || !results) return;
    const query = input.value.trim().toLowerCase();
    if (!query) return closeSearch();
    const matches = pages.filter((page) => `${page.title} ${page.description}`.toLowerCase().includes(query)).slice(0,6);
    results.replaceChildren();
    matches.forEach((page) => {
      const link = document.createElement('a'); const title = document.createElement('strong'); const description = document.createElement('small');
      link.href = page.href; link.setAttribute('role','option'); title.textContent = page.title; description.textContent = page.description; link.append(title,description); results.append(link);
    });
    if (!matches.length) { const message = document.createElement('p'); message.textContent = 'No notes found.'; results.append(message); }
    results.hidden = false; input.setAttribute('aria-expanded','true');
  }
  input?.addEventListener('input',runSearch);
  input?.addEventListener('keydown',(event) => { if (event.key === 'ArrowDown' && !results?.hidden) { event.preventDefault(); results?.querySelector<HTMLAnchorElement>('a')?.focus(); } });
  results?.addEventListener('keydown',(event) => {
    const options = [...results.querySelectorAll<HTMLAnchorElement>('a')]; const current = options.indexOf(document.activeElement as HTMLAnchorElement);
    if (event.key === 'ArrowDown') { event.preventDefault(); options[(current + 1) % options.length]?.focus(); }
    if (event.key === 'ArrowUp') { event.preventDefault(); current <= 0 ? input?.focus() : options[current - 1]?.focus(); }
  });
  document.addEventListener('keydown',(event) => { if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') { event.preventDefault(); input?.focus(); input?.select(); } if (event.key === 'Escape') closeSearch(); });
  document.addEventListener('click',(event) => { if (!shell?.contains(event.target as Node)) closeSearch(); });
</script>
